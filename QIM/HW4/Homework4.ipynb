   "source": [
    "n = 1  # one year\n",
    "mu_p = mu_a / n\n",
    "sigma_p = sigma_a / np.sqrt(n)\n",
    "p_loss = stats.norm.cdf(0.0, loc=mu_p, scale=sigma_p)\n",
    "\n",
    "print(\"A(i)  P(loss in a given year)\")\n",
    "print(f\"      \u03bc_year = {mu_p:.4f}, \u03c3_year = {sigma_p:.4f}\")\n",
    "print(f\"      Answer: {p_loss:.6f}  ({100*p_loss:.4f}%)\")"
